<?xml version="1.0" encoding="utf-8"?>
<Container>
    <TemplateURL>https://raw.githubusercontent.com/micahmo/docker-templates/master/micahmo/mosquitto.xml</TemplateURL>
    <Name>Mosquitto</Name>
    <Project>https://mosquitto.org/</Project>
    <Overview>Eclipse Mosquitto - An open source MQTT broker. Before starting, create /mnt/user/appdata/mosquitto/config/mosquitto.conf and /mnt/user/appdata/mosquitto/config/passwd (use mosquitto_passwd to generate).</Overview>
    <Description>Eclipse Mosquitto - An open source MQTT broker.</Description>
    <Registry>https://registry.hub.docker.com/r/eclipse-mosquitto</Registry>
    <GitHub>https://github.com/eclipse-mosquitto/mosquitto</GitHub>
    <Repository>eclipse-mosquitto</Repository>
    <Icon>https://mosquitto.org/images/mosquitto-text-side-28.png</Icon>
    <Networking>
        <Mode>bridge</Mode>
        <Publish>
            <Port>
                <HostPort>1883</HostPort>
                <ContainerPort>1883</ContainerPort>
                <Protocol>tcp</Protocol>
            </Port>
        </Publish>
    </Networking>
    <Config Type="Path" Name="Config Path" Target="/mosquitto/config" Default="/mnt/user/appdata/mosquitto/config" Mode="rw" Description="Path to mosquitto.conf and passwd file." Required="true">/mnt/user/appdata/mosquitto/config</Config>
    <Config Type="Path" Name="Data Path" Target="/mosquitto/data" Default="/mnt/user/appdata/mosquitto/data" Mode="rw" Description="Path for persistent message storage." Required="true">/mnt/user/appdata/mosquitto/data</Config>
    <Config Type="Path" Name="Log Path" Target="/mosquitto/log" Default="/mnt/user/appdata/mosquitto/log" Mode="rw" Description="Path for log files." Required="false">/mnt/user/appdata/mosquitto/log</Config>
    <RestartPolicy>unless-stopped</RestartPolicy>
</Container>
